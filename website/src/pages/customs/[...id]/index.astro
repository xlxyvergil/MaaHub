---
import Layout from '../../../layouts/Layout.astro';
import { CustomDetailApp } from '../../../components/CustomDetailApp';
import { getCollection } from 'astro:content';
import { withDownloadFiles } from '../../../lib/downloadFiles';

export async function getStaticPaths() {
  const customs = await getCollection('customs');
  return Promise.all(customs.map(async (custom: typeof customs[number]) => ({
    params: { id: custom.data.id },
    props: { custom: await withDownloadFiles(custom.data, 'customs') },
  })));
}

const { id } = Astro.params;
const { custom } = Astro.props;
---

<Layout title={`MaaHub - ${custom.title}`}>
  <CustomDetailApp customId={id} customData={custom} client:only="react" />
</Layout>
