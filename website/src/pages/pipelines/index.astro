---
import Layout from '../../layouts/Layout.astro';
import { PipelinesApp } from '../../components/PipelinesApp';
import { getCollection } from 'astro:content';

const pipelines = await getCollection('pipelines');
const pipelinesData = pipelines.map(p => p.data);
---

<Layout title="MaaHub - AI Pipelines">
  <PipelinesApp client:only="react" pipelinesData={pipelinesData} />
</Layout>