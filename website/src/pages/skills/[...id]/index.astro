---
import Layout from '../../../layouts/Layout.astro';
import { SkillDetailApp } from '../../../components/SkillDetailApp';
import { withDownloadFiles } from '../../../lib/downloadFiles';
import { getAllSkills } from '../../../lib/skills';

export async function getStaticPaths() {
  const skills = await getAllSkills();
  return Promise.all(skills.map(async (skill) => {
    return {
      params: { id: skill.id },
      props: { skill: await withDownloadFiles(skill, 'skills') },
    };
  }));
}

const { id } = Astro.params;
const { skill } = Astro.props;
---

<Layout title={`${skill.title} - MaaHub`}>
  <SkillDetailApp client:only="react" skillId={id} skillData={skill} />
</Layout>
