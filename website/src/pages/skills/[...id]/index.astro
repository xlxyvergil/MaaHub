---
import Layout from '../../../layouts/Layout.astro';
import { SkillDetailApp } from '../../../components/SkillDetailApp';
import { getCollection } from 'astro:content';
import { withDownloadFiles } from '../../../lib/downloadFiles';

export async function getStaticPaths() {
  const skills = await getCollection('skills');
  return Promise.all(skills.map(async (skill: typeof skills[number]) => {
    return {
      params: { id: skill.data.id },
      props: { skill: await withDownloadFiles(skill.data, 'skills') },
    };
  }));
}

const { id } = Astro.params;
const { skill } = Astro.props;
---

<Layout title={`${skill.title} - MaaHub`}>
  <SkillDetailApp client:only="react" skillId={id} skillData={skill} />
</Layout>
