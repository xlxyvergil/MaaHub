{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maahub.dev/schema/maahub-meta.schema.json",
  "title": "MaaHub Meta",
  "description": "Unified metadata schema for MaaHub skills, pipelines, customs, and experiences.",
  "oneOf": [
    { "$ref": "#/$defs/skillMeta" },
    { "$ref": "#/$defs/pipelineMeta" },
    { "$ref": "#/$defs/customMeta" },
    { "$ref": "#/$defs/experienceMeta" }
  ],
  "$defs": {
    "status": {
      "type": "string",
      "enum": ["stable", "beta", "deprecated", "experimental"]
    },
    "commonMeta": {
      "type": "object",
      "required": [
        "id",
        "title",
        "description",
        "author",
        "createdAt",
        "updatedAt",
        "entry",
        "readme",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[^/]+/[^/]+$",
          "description": "Unique entry id in the form author/slug."
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "author": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "createdAt": {
          "type": "string",
          "format": "date"
        },
        "updatedAt": {
          "type": "string",
          "format": "date"
        },
        "version": {
          "type": "string"
        },
        "mfwVersion": {
          "type": "string",
          "description": "Target MaaFramework version or compatibility baseline."
        },
        "entry": {
          "type": "string",
          "minLength": 1,
          "description": "Primary entry file path, relative to the entry directory."
        },
        "readme": {
          "type": "string",
          "minLength": 1,
          "description": "Primary documentation file path, relative to the entry directory."
        },
        "status": {
          "$ref": "#/$defs/status"
        },
        "type": {
          "type": "string",
          "enum": ["skill", "pipeline", "custom", "experience"]
        },
        "category": {
          "type": "string"
        },
        "externalTools": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true,
          "description": "External tools, services, or runtimes that consumers should know about."
        }
      }
    },
    "skillMeta": {
      "allOf": [
        { "$ref": "#/$defs/commonMeta" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "skill" },
            "inputs": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "outputs": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "pipelineMeta": {
      "allOf": [
        { "$ref": "#/$defs/commonMeta" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "pipeline" }
          },
          "additionalProperties": false
        }
      ]
    },
    "customMeta": {
      "allOf": [
        { "$ref": "#/$defs/commonMeta" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "custom" },
            "language": {
              "type": "string"
            },
            "runtime": {
              "type": "string"
            },
            "dependencies": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "chapter": {
      "type": "object",
      "required": ["title", "path"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "path": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "experienceMeta": {
      "allOf": [
        { "$ref": "#/$defs/commonMeta" },
        {
          "type": "object",
          "properties": {
            "type": { "const": "experience" },
            "chapters": {
              "type": "array",
              "items": { "$ref": "#/$defs/chapter" }
            },
            "difficulty": {
              "type": "string",
              "enum": ["beginner", "intermediate", "advanced"]
            },
            "estimatedTime": {
              "type": "string",
              "description": "Human-readable reading or completion time, for example 10min or 1h."
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
